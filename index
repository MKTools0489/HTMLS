<style>
:root{
  --blue:#2D3DBE; --cream:#F0EAD6;
  --black:#0e0e0e; --white:#f0ede8;
  --mid:#888; --gold:#c89a1a;
  --serif:'DM Serif Display',Georgia,serif;
  --sans:'DM Sans',sans-serif;
  --mono:'DM Mono',monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden}
body{font-family:var(--sans);background:var(--black);color:var(--white);}

/* ── DECK ── */
.deck{
  position:fixed;
  top:0;left:0;right:0;
  bottom:52px;          /* exactly the nav height */
  overflow:hidden;
}

/* every slide fills the deck exactly, hidden by default */
.slide{
  position:absolute;
  inset:0;
  overflow:hidden;
  display:none;         /* hidden */
  background:var(--black);
}
.slide.active{display:block}  /* shown */

/* NAV BAR — always on top */
.nav{
  position:fixed;
  bottom:0;left:0;right:0;
  height:52px;z-index:9999;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;
  background:rgba(10,10,10,0.98);
  border-top:1px solid rgba(255,255,255,0.07);
}
.dots{display:flex;gap:7px}
.dot{width:6px;height:6px;border-radius:50%;background:#444;cursor:pointer;transition:all .2s}
.dot.on{background:var(--blue);width:20px;border-radius:3px}
.nbtn{font-family:var(--mono);font-size:11px;letter-spacing:.09em;padding:7px 18px;border:1px solid rgba(255,255,255,0.14);background:transparent;color:var(--white);cursor:pointer;border-radius:2px;transition:all .2s}
.nbtn:hover{background:rgba(255,255,255,0.07)}
.nbtn:disabled{opacity:.25;cursor:not-allowed}
.nbtn.p{background:var(--blue);border-color:var(--blue)}
.ctr{font-family:var(--mono);font-size:11px;color:#444;letter-spacing:.1em}
.prog{position:fixed;top:0;left:0;height:3px;background:var(--blue);z-index:9999;transition:width .35s ease}

/* ── LAYOUTS ── */
.fill{width:100%;height:100%;}
.row{display:flex;height:100%}
.half{flex:1;overflow:hidden;display:flex;flex-direction:column;justify-content:center;padding:28px 40px}
.half.b{border-right:1px solid rgba(255,255,255,0.06)}
.half.blue{background:var(--blue);flex:1;display:flex;flex-direction:column;justify-content:center;padding:28px 44px}
.full-pad{padding:28px 52px 20px;height:100%;display:flex;flex-direction:column;overflow:hidden}

/* ── TYPOGRAPHY ── */
.num{font-family:var(--mono);font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--blue);border:1px solid var(--blue);padding:2px 8px;border-radius:2px;display:inline-block;margin-bottom:7px}
.num-w{font-family:var(--mono);font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:rgba(240,234,214,0.5);border:1px solid rgba(240,234,214,0.3);padding:2px 8px;border-radius:2px;display:inline-block;margin-bottom:7px}
.cat{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#555;margin-bottom:7px}
.cat-w{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:rgba(240,234,214,0.4);margin-bottom:7px}
.ttl{font-family:var(--serif);font-size:clamp(24px,2.8vw,40px);line-height:1.05;margin-bottom:11px}
.acc{color:var(--blue);font-style:italic}
.acc-cr{color:var(--cream);font-style:italic}
.bod{font-size:13px;line-height:1.68;color:#aaa;max-width:460px}
.ins{margin-top:12px;padding:12px 16px;border-left:3px solid var(--blue);background:rgba(45,61,190,0.07);border-radius:0 4px 4px 0}
.ins .il{font-family:var(--mono);font-size:8px;letter-spacing:.18em;text-transform:uppercase;color:var(--blue);margin-bottom:5px}
.ins p{font-size:12.5px;font-style:italic;color:#ddd;line-height:1.5}
.ss{border:1px solid rgba(255,255,255,0.09);border-radius:5px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.7);width:100%}
.ss img{width:100%;display:block}

@keyframes fu{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.slide.active .ttl,.slide.active .bod{animation:fu .38s ease forwards}
</style>
</head>
