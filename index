<script>
const slides=document.querySelectorAll('.slide');
const N=slides.length;
let cur=0;
const DC=document.getElementById('dots');
for(let i=0;i<N;i++){const d=document.createElement('div');d.className='dot'+(i===0?' on':'');d.onclick=()=>go(i);DC.appendChild(d);}
function go(n){slides[cur].classList.remove('active');cur=Math.max(0,Math.min(n,N-1));slides[cur].classList.add('active');upd();}
function next(){go(cur+1)}
function prev(){go(cur-1)}
function upd(){
  document.querySelectorAll('.dot').forEach((d,i)=>d.classList.toggle('on',i===cur));
  document.getElementById('ctr').textContent=String(cur+1).padStart(2,'0')+' / '+String(N).padStart(2,'0');
  document.getElementById('pb').disabled=cur===0;
  document.getElementById('nb').disabled=cur===N-1;
  document.getElementById('prog').style.width=((cur+1)/N*100).toFixed(1)+'%';
}
document.addEventListener('keydown',e=>{if(e.key==='ArrowRight'||e.key==='ArrowDown')next();if(e.key==='ArrowLeft'||e.key==='ArrowUp')prev();});
upd();
</script>
